#!/usr/bin/env bash
set -Eeuo pipefail

PORTS_CONF="/etc/vps-bootstrap/ports.conf"

PORT="${1:-}"
PROTO="${2:-}"
NAME="${3:-custom}"

usage() {
  echo "Usage:"
  echo "  vps-open-port PORT tcp|udp [name]"
  echo
  echo "Example:"
  echo "  vps-open-port 8443 tcp x-ui"
  echo "  vps-open-port 51820 udp wireguard"
}

if [[ -z "$PORT" || -z "$PROTO" ]]; then
  usage
  exit 1
fi

if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [[ "$PORT" -lt 1 || "$PORT" -gt 65535 ]]; then
  echo "Invalid port: $PORT"
  exit 1
fi

if [[ "$PROTO" != "tcp" && "$PROTO" != "udp" ]]; then
  echo "Protocol must be tcp or udp"
  exit 1
fi

source "$PORTS_CONF"

VAR_NAME="TCP_PORTS"
[[ "$PROTO" == "udp" ]] && VAR_NAME="UDP_PORTS"

CURRENT="${!VAR_NAME}"

if echo "$CURRENT" | awk -F: '{print $1}' | grep -qx "$PORT"; then
  echo "$PROTO/$PORT already exists"
  exit 0
fi

NEW_LINE="${PORT}:${NAME}"

python3 - "$PORTS_CONF" "$VAR_NAME" "$NEW_LINE" <<'PY'
import sys, re

path, var, new_line = sys.argv[1], sys.argv[2], sys.argv[3]

text = open(path).read()

pattern = rf'{var}="\n(.*?)\n"'

def repl(match):
    body = match.group(1).rstrip()
    return f'{var}="\\n{body}\\n{new_line}\\n"'

text = re.sub(pattern, repl, text, flags=re.S)

open(path, "w").write(text)
PY

vps-reload-fw

echo "Opened $PROTO/$PORT ($NAME)"
