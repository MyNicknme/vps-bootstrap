#!/usr/bin/env bash
set -Eeuo pipefail

PORTS_CONF="/etc/vps-bootstrap/ports.conf"

PORT="${1:-}"
PROTO="${2:-}"
NAME="${3:-custom}"

usage() {
  echo "Usage:"
  echo "  vps-open-port PORT tcp|udp [name]"
  echo
  echo "Example:"
  echo "  vps-open-port 8443 tcp x-ui"
  echo "  vps-open-port 51820 udp wireguard"
}

if [[ -z "$PORT" || -z "$PROTO" ]]; then
  usage
  exit 1
fi

if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [[ "$PORT" -lt 1 || "$PORT" -gt 65535 ]]; then
  echo "Invalid port: $PORT"
  exit 1
fi

if [[ "$PROTO" != "tcp" && "$PROTO" != "udp" ]]; then
  echo "Protocol must be tcp or udp"
  exit 1
fi

if [[ ! -f "$PORTS_CONF" ]]; then
  echo "Ports config not found: $PORTS_CONF"
  exit 1
fi

VAR_NAME="TCP_PORTS"
[[ "$PROTO" == "udp" ]] && VAR_NAME="UDP_PORTS"

python3 - "$PORTS_CONF" "$VAR_NAME" "$PORT" "$NAME" <<'PY'
import sys
import re

path, var, port, name = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

with open(path, "r") as f:
    text = f.read()

pattern = rf'{var}="\n(.*?)\n"'
match = re.search(pattern, text, flags=re.S)

if not match:
    print(f"{var} not found")
    sys.exit(1)

body = match.group(1)
lines = [line.strip() for line in body.splitlines() if line.strip()]

for line in lines:
    if line.split(":", 1)[0] == port:
        print(f"{port} already exists")
        sys.exit(0)

lines.append(f"{port}:{name}")

new_block = var + '="\n' + "\n".join(lines) + '\n"'
text = re.sub(pattern, new_block, text, flags=re.S)

with open(path, "w") as f:
    f.write(text)
PY

vps-reload-fw

echo "Opened $PROTO/$PORT ($NAME)"
