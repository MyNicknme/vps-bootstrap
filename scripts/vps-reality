#!/usr/bin/env bash
set -Eeuo pipefail

INSTALL_DIR="/opt/realitlscanner"
BIN="/usr/local/bin/RealiTLScanner"
VERSION="v0.2.3"

show_help() {
cat <<EOF
Usage:
  vps reality install-scanner
  vps reality scan IP_OR_CIDR
  vps reality scan-current

Examples:
  vps reality install-scanner
  vps reality scan 50.114.113.96/24
  vps reality scan-current
EOF
}

install_scanner() {
  mkdir -p "$INSTALL_DIR"

  arch="$(uname -m)"

  case "$arch" in
    x86_64|amd64)
      pattern="linux.*amd64|amd64.*linux|linux.*64"
      ;;
    aarch64|arm64)
      pattern="linux.*arm64|arm64.*linux"
      ;;
    *)
      echo "Unsupported architecture: $arch"
      exit 1
      ;;
  esac

  echo "Finding latest RealiTLScanner release..."

  url="$(
    curl -fsSL --connect-timeout 10 --max-time 30 \
      https://api.github.com/repos/XTLS/RealiTLScanner/releases/latest |
    jq -r --arg pattern "$pattern" '
      .assets[]
      | select(.name | test($pattern; "i"))
      | .browser_download_url
    ' | head -n1
  )"

  if [[ -z "$url" || "$url" == "null" ]]; then
    echo "Could not find suitable RealiTLScanner binary"
    exit 1
  fi

  echo "Downloading:"
  echo "$url"

  curl -fL --connect-timeout 10 --max-time 120 "$url" -o "$BIN"
  chmod +x "$BIN"

  if ! file "$BIN" | grep -q "ELF"; then
    echo "Downloaded file is not a Linux binary:"
    file "$BIN"
    exit 1
  fi

  echo "Installed:"
  "$BIN" -h || true
}

scan_target() {
  target="${1:-}"

  if [[ -z "$target" ]]; then
    echo "Target is required"
    echo
    show_help
    exit 1
  fi

  if [[ ! -x "$BIN" ]]; then
    echo "RealiTLScanner is not installed."
    echo "Run:"
    echo "  vps reality install-scanner"
    exit 1
  fi

  mkdir -p /root/reality-scans

  ts="$(date +%Y%m%d-%H%M%S)"
  out="/root/reality-scans/scan-${ts}.csv"

  echo "Scanning: $target"
  echo "Output: $out"
  echo

  "$BIN" -addr "$target" -out "$out"

  echo
  echo "Done."
  echo "Result saved to:"
  echo "$out"
}

scan_current() {
  ip="$(curl -4 -s --max-time 5 ifconfig.me)"

  if [[ -z "$ip" ]]; then
    echo "Unable to detect public IPv4"
    exit 1
  fi

  base="$(echo "$ip" | awk -F. '{print $1"."$2"."$3".0/24"}')"

  scan_target "$base"
}

cmd="${1:-help}"

case "$cmd" in
  install-scanner)
    install_scanner
    ;;

  scan)
    shift
    scan_target "${1:-}"
    ;;

  scan-current)
    scan_current
    ;;

  help|-h|--help)
    show_help
    ;;

  *)
    echo "Unknown reality command: $cmd"
    echo
    show_help
    exit 1
    ;;
esac
