#!/usr/bin/env bash

green="✔"
red="✘"

check_service() {
  if systemctl is-active --quiet "$1"; then
    echo "$green Running"
  else
    echo "$red Not running"
  fi
}

check_enabled() {
  if systemctl is-enabled --quiet "$1"; then
    echo "$green Enabled"
  else
    echo "$red Disabled"
  fi
}

public_ipv4=$(curl -4 -s --max-time 3 ifconfig.me || echo "N/A")
public_ipv6=$(curl -6 -s --max-time 3 ifconfig.me || echo "N/A")

os_name=$(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')
kernel=$(uname -r)
host=$(hostname)
uptime_info=$(uptime -p)

memory_used=$(free -h | awk '/Mem:/ {print $3}')
memory_total=$(free -h | awk '/Mem:/ {print $2}')

disk_used=$(df -h / | awk 'NR==2 {print $3}')
disk_total=$(df -h / | awk 'NR==2 {print $2}')

bbr=$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null)
ip_forward=$(sysctl -n net.ipv4.ip_forward 2>/dev/null)
ipv6_forward=$(sysctl -n net.ipv6.conf.all.forwarding 2>/dev/null)

echo "========================================="
echo " VPS Bootstrap Status"
echo "========================================="
echo
echo "Hostname      : $host"
echo "OS            : $os_name"
echo "Kernel        : $kernel"
echo "Uptime        : $uptime_info"
echo
echo "Memory        : $memory_used / $memory_total"
echo "Disk          : $disk_used / $disk_total"
echo
echo "-----------------------------------------"
echo "Public IPv4   : $public_ipv4"
echo "Public IPv6   : $public_ipv6"
echo
echo "-----------------------------------------"
echo "Firewall      : $(check_service nftables)"
echo "Fail2Ban      : $(check_service fail2ban)"
echo "SSH           : $(check_service ssh)"
echo
echo "nftables boot : $(check_enabled nftables)"
echo "Fail2Ban boot : $(check_enabled fail2ban)"
echo
echo "-----------------------------------------"

[[ "$bbr" == "bbr" ]] && echo "TCP BBR       : $green Enabled" || echo "TCP BBR       : $red Disabled"
[[ "$ip_forward" == "1" ]] && echo "IP Forward    : $green Enabled" || echo "IP Forward    : $red Disabled"
[[ "$ipv6_forward" == "1" ]] && echo "IPv6 Forward  : $green Enabled" || echo "IPv6 Forward  : $red Disabled"

echo
echo "-----------------------------------------"
echo "Listening TCP ports:"
ss -tuln | awk '/tcp/ {print $5}' | sed 's/.*://' | sort -n | uniq

echo
echo "Listening UDP ports:"
ss -tuln | awk '/udp/ {print $5}' | sed 's/.*://' | sort -n | uniq

echo
echo "-----------------------------------------"
echo "Fail2Ban:"
fail2ban-client status sshd 2>/dev/null || echo "sshd jail not active"

echo
echo "-----------------------------------------"
if [[ -f /var/run/reboot-required ]]; then
  echo "Reboot required: Yes"
else
  echo "Reboot required: No"
fi

echo
echo "========================================="
echo " VPS READY FOR VPN INSTALLATION"
echo "========================================="
